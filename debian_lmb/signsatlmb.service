[Unit]
Description=signsatlmb

[Service]
Type=simple
ExecStart=/usr/bin/java -Xmx200m -Dsun.jnu.encoding=UTF-8 -Dfile.encoding=UTF-8 -jar /usr/share/java/signsatlmb/signsatlmb.jar --spring.config.additional-location=optional:file:/etc/signsatlmb/ --spring.profiles.active=lmb

[Install]
WantedBy=multi-user.target
